if(DEFINED CDD_CHARSET)
    if(CDD_CHARSET STREQUAL "UNICODE")
        set(C_ABSTRACT_HTTP_UNICODE ON)
        set(C_ABSTRACT_HTTP_ANSI OFF)
    elseif(CDD_CHARSET STREQUAL "ANSI")
        set(C_ABSTRACT_HTTP_UNICODE OFF)
        set(C_ABSTRACT_HTTP_ANSI ON)
    endif()
endif()

if(DEFINED CDD_THREADING)
    if(CDD_THREADING STREQUAL "ON")
        set(C_ABSTRACT_HTTP_MULTI_THREADED ON)
        set(C_ABSTRACT_HTTP_SINGLE_THREADED OFF)
    elseif(CDD_THREADING STREQUAL "OFF")
        set(C_ABSTRACT_HTTP_MULTI_THREADED OFF)
        set(C_ABSTRACT_HTTP_SINGLE_THREADED ON)
    endif()
endif()

if(DEFINED CDD_MSVC_RTC)
    if(CDD_MSVC_RTC STREQUAL "RTC1")
        set(C_ABSTRACT_HTTP_RTC1 ON)
    elseif(CDD_MSVC_RTC STREQUAL "RTCs")
        set(C_ABSTRACT_HTTP_RTCs ON)
    elseif(CDD_MSVC_RTC STREQUAL "RTCu")
        set(C_ABSTRACT_HTTP_RTCu ON)
    endif()
endif()
